// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id        String   @id @default(uuid())

  name      String

  email     String?   @unique

  username  String   @unique

  password  String

  role      UserRole @default(STUDENT)

  createdAt DateTime @default(now())

  groupMemberships GroupMember[]

  createdExams Exam[]

  examAttempts ExamAttempt[]
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  members GroupMember[]
  exams   Exam[]
}

model GroupMember {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model Exam {
  id          String  @id @default(uuid())
  title       String
  description String?
  duration    Int
  passMark    Int

  markingSystem MarkingSystem @default(STANDARD)

  correctMarks Float @default(1)
  wrongMarks   Float @default(0)
  createdAt DateTime @default(now())

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id])

  questions Question[]
  attempts  ExamAttempt[]
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum MarkingSystem {
  STANDARD
  NEGATIVE
  CUSTOM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model Question {
  id         String       @id @default(uuid())
  question   String
  type       QuestionType
  difficulty Difficulty

  createdAt DateTime @default(now())

  examId String?
  exam   Exam?   @relation(fields: [examId], references: [id])

  options QuestionOption[]
  answers Answer[]
}

model QuestionOption {
  id String @id @default(uuid())

  optionText String

  isCorrect Boolean

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  selectedOptions SelectedOption[]
}

model ExamAttempt {
  id String @id @default(uuid())

  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  score Float?

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  examId String
  exam   Exam   @relation(fields: [examId], references: [id])

  answers Answer[]
}

model Answer {
  id String @id @default(uuid())

  attemptId String
  attempt   ExamAttempt @relation(fields: [attemptId], references: [id])

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  isCorrect Boolean

  selectedOptions SelectedOption[]
}

model SelectedOption {
  id String @id @default(uuid())

  answerId String
  answer   Answer @relation(fields: [answerId], references: [id])

  optionId String
  option   QuestionOption @relation(fields: [optionId], references: [id])

  @@unique([answerId, optionId])
}
